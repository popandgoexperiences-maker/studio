{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the InvoiceFlow application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity (matches Firebase Auth UID)."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "nif": {
          "type": "string",
          "description": "The user's NIF (Número de Identificación Fiscal)."
        },
        "address": {
          "type": "string",
          "description": "The user's address."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL or Data URI of the user's company logo."
        },
        "signatureUrl": {
          "type": "string",
          "description": "Data URI of the user's signature image."
        },
        "sealUrl": {
          "type": "string",
          "description": "URL or Data URI of the user's company seal image."
        },
        "vatRate": {
            "type": "number",
            "description": "The default VAT rate for the user (e.g., 0.21 for 21%)."
        }
      },
      "required": [
        "id",
        "name",
        "email"
      ]
    },
    "Client": {
        "title": "Client",
        "type": "object",
        "description": "Represents a client of a user.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "nif": { "type": "string" },
            "address": { "type": "string" }
        },
        "required": ["name", "nif", "address"]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice generated by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Invoice entity."
        },
        "userId": {
            "type": "string",
            "description": "The UID of the user who owns this invoice."
        },
        "invoiceNumber": {
          "type": "string",
          "description": "The invoice number (e.g., F-001)."
        },
        "client": {
            "$ref": "#/entities/Client"
        },
        "lineItems": {
          "type": "array",
          "description": "An array of line items in the invoice.",
          "items": {
            "type": "object",
            "properties": {
                "description": { "type": "string" },
                "quantity": { "type": "number" },
                "unitPrice": { "type": "number" }
            },
            "required": ["description", "quantity", "unitPrice"]
          }
        },
        "subtotal": {
          "type": "number",
          "description": "The subtotal amount of the invoice."
        },
        "vat": {
          "type": "number",
          "description": "The VAT amount of the invoice."
        },
        "total": {
          "type": "number",
          "description": "The total amount of the invoice (including VAT)."
        },
        "date": {
          "type": "string",
          "description": "The date the invoice was created (ISO 8601).",
          "format": "date-time"
        },
        "status": {
            "type": "string",
            "enum": ["draft", "pending", "paid", "generating"]
        },
        "pdfUrl": {
          "type": "string",
          "description": "URL of the generated PDF invoice."
        }
      },
      "required": [
        "userId",
        "invoiceNumber",
        "client",
        "lineItems",
        "subtotal",
        "vat",
        "total",
        "date",
        "status"
      ]
    },
    "Quote": {
      "title": "Quote",
      "type": "object",
      "description": "Represents a quote generated by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Quote entity."
        },
        "userId": {
            "type": "string",
            "description": "The UID of the user who owns this quote."
        },
        "quoteNumber": {
          "type": "string",
          "description": "The quote number (e.g., P-001)."
        },
        "client": {
            "$ref": "#/entities/Client"
        },
        "lineItems": {
          "type": "array",
          "description": "An array of line items in the quote.",
          "items": {
            "type": "object",
            "properties": {
                "description": { "type": "string" },
                "quantity": { "type": "number" },
                "unitPrice": { "type": "number" }
            },
            "required": ["description", "quantity", "unitPrice"]
          }
        },
        "subtotal": {
          "type": "number"
        },
        "vat": {
          "type": "number"
        },
        "total": {
          "type": "number"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
            "type": "string",
            "enum": ["draft", "sent", "accepted", "rejected"]
        },
        "pdfUrl": {
          "type": "string"
        },
        "invoiceId": {
          "type": "string"
        }
      },
      "required": [
        "userId",
        "quoteNumber",
        "client",
        "lineItems",
        "subtotal",
        "vat",
        "total",
        "date",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/entities/User"
          },
          "description": "Stores user profiles. Each document is owned by the user with the matching userId."
        }
      },
      {
        "path": "/users/{userId}/clients/{clientId}",
        "definition": {
            "entityName": "Client",
            "schema": {
                "$ref": "#/entities/Client"
            },
            "description": "Stores clients for a specific user."
        }
      },
      {
        "path": "/users/{userId}/invoices/{invoiceId}",
        "definition": {
          "entityName": "Invoice",
          "schema": {
            "$ref": "#/entities/Invoice"
          },
          "description": "Stores invoices created by each user."
        }
      },
      {
        "path": "/users/{userId}/quotes/{quoteId}",
        "definition": {
          "entityName": "Quote",
          "schema": {
            "$ref": "#/entities/Quote"
          },
          "description": "Stores quotes created by each user."
        }
      }
    ]
  }
}
