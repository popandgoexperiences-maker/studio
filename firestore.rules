rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de ayuda para las reglas ---

    // Comprueba si el usuario que realiza la solicitud está autenticado.
    function isSignedIn() {
      return request.auth != null;
    }

    // Comprueba si el usuario autenticado es el propietario del documento.
    // Esta es la función clave para la seguridad por usuario.
    // Para depurar: Si esta función falla, significa que el UID del usuario que ha iniciado sesión
    // (request.auth.uid) no coincide con el ID del documento al que se intenta acceder (userId).
    // Ejemplo de depuración:
    //   - request.auth.uid (UID del token del usuario): "abc-123"
    //   - userId (ID del documento en el path): "xyz-789"
    //   - Resultado: false (acceso denegado)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Reglas para la colección 'users' ---

    // El comodín {userId} captura el ID del documento, que debe coincidir con el UID del usuario.
    match /users/{userId} {

      // REGLA DE LECTURA Y ACTUALIZACIÓN:
      // Solo permite la lectura (get) y actualización (update) si la función isOwner(userId) devuelve 'true'.
      // Esto garantiza que un usuario solo pueda leer y modificar su propio perfil.
      allow read, update: if isOwner(userId);
      
      // REGLA DE CREACIÓN:
      // Permite a un nuevo usuario crear su propio perfil.
      // La condición asegura que el UID del usuario que crea el documento
      // coincida con el ID del documento que se va a crear.
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Se deniega 'delete' y 'list' por defecto para mayor seguridad.
      // 'list' se bloquea para evitar que un usuario pueda listar todos los UIDs de la base de datos.

      // --- Reglas para sub-colecciones ---

      // Un usuario puede gestionar sus propias facturas dentro de su perfil.
      match /invoices/{invoiceId} {
        allow read, write, delete: if isOwner(userId);
      }
      
      // Un usuario puede gestionar sus propios clientes dentro de su perfil.
      match /clients/{clientId} {
        allow read, write, delete: if isOwner(userId);
      }
    }
  }
}
