
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de ayuda para las reglas ---

    // Comprueba si el usuario que realiza la solicitud está autenticado.
    function isSignedIn() {
      return request.auth != null;
    }

    // Comprueba si el usuario autenticado es el propietario del documento.
    // Esta es la función clave para la seguridad por usuario.
    // Para depurar: Si esta función falla, significa que el UID del usuario que ha iniciado sesión
    // (request.auth.uid) no coincide con el ID del documento al que se intenta acceder (userId).
    // Ejemplo de depuración:
    //   - request.auth.uid (UID del token del usuario): "abc-123"
    //   - userId (ID del documento en el path): "xyz-789"
    //   - Resultado: false (acceso denegado)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Reglas para la colección 'users' ---

    // El comodín {userId} captura el ID del documento, que debe coincidir con el UID del usuario.
    match /users/{userId} {

      // REGLA DE LECTURA (TEMPORALMENTE RELAJADA PARA DEPURACIÓN):
      // Permite a CUALQUIER usuario autenticado LEER CUALQUIER perfil.
      // Esto es útil durante el desarrollo para verificar datos sin restricciones.
      // En producción, esto debería cambiarse a: allow read: if isOwner(userId);
      allow read: if isSignedIn();

      // REGLA DE ESCRITURA (SEGURA):
      // Solo permite crear, actualizar o borrar si el usuario es el propietario del documento.
      // La función isOwner(userId) asegura que request.auth.uid coincida con el {userId} del path.
      allow write: if isOwner(userId);

      // --- Reglas para sub-colecciones ---

      // Un usuario puede gestionar sus propias facturas y clientes.
      // La regla isOwner(userId) del path padre se aplica aquí también.
      match /invoices/{invoiceId} {
        allow read, write, delete: if isOwner(userId);
      }
      
      match /clients/{clientId} {
        allow read, write, delete: if isOwner(userId);
      }
    }
  }
}
