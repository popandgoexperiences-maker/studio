rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // /users/{userId}
    match /users/{userId} {
      // Users can read and update their own profile.
      allow read, update: if isOwner(userId);
      // New users can create their own profile document.
      allow create: if isSignedIn() && request.auth.uid == userId;

      // /users/{userId}/invoices/{invoiceId}
      match /invoices/{invoiceId} {
        // Allow owner to read their own list of invoices and individual invoices.
        allow read, list: if isOwner(userId);
        // Allow owner to write/update/delete only if the invoice's userId field matches.
        allow create, update, delete: if isOwner(userId) && request.resource.data.userId == userId;
      }
      
      // /users/{userId}/clients/{clientId}
      match /clients/{clientId} {
        // Only the owner can manage their clients.
        allow read, list, create, update, delete: if isOwner(userId);
      }
    }
  }
}
